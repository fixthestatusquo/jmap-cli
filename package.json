{
  "name": "jmap-cli",
  "version": "2.2.0",
  "description": "A command-line interface for JMAP servers.",
  "type": "module",
  "main": "./lib/jmap.js",
  "types": "./lib/jmap.d.ts",
  "exports": {
    ".": {
      "types": "./lib/jmap.d.ts",
      "default": "./lib/jmap.js"
    }
  },
  "bin": "./bin/jmap.js",
  "files": [
    "bin",
    "lib",
    "README.md"
  ],
  "typesVersions": {
    "*": {
      "auth": [
        "./lib/auth.d.ts"
      ],
      "display": [
        "./lib/display.d.ts"
      ],
      "errors": [
        "./lib/errors.d.ts"
      ],
      "oauth": [
        "./lib/oauth.d.ts"
      ]
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "init": "./bin/init.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fixthestatusquo/jmap-cli.git"
  },
  "keywords": [
    "jmap",
    "cli",
    "email"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "minimist": "^1.2.8",
    "ws": "^8.17.0"
  }
}

